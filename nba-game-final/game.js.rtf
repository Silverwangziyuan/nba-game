const state = \{\
    swaps: 1,\
    times: 1,\
    currentTeam: 'Lakers',\
    currentEra: '1990s',\
    slots: \{\}\
\};\
\
// \uc0\u27169 \u25311 \u29699 \u21592 \u25968 \u25454 \u65288 \u32431 \u26412 \u22320 \u65292 \u26080 \u38656 \u32852 \u32593 \u65289 \
